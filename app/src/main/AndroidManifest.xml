<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Open sockets (bind the on-device HTTP server; also loopback WebView). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- WifiLock (keep the Wi-Fi radio up in Doze so hotspot ingest continues). -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Partial wake lock: keep the CPU up so the ServerSocket keeps accepting. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Foreground service so the Node process survives Doze / screen-off. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Ongoing notification (runtime-granted on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Ask to be exempt from battery optimization (OEM killers). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Tripwire"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".NodeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <!-- Required for the specialUse FGS type on Android 14+. This app is
                 sideloaded/enterprise; the subtype documents the use case. -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="passive_ble_emissions_tripwire_local_sensor_ingest" />
        </service>

    </application>
</manifest>
